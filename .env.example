# Copy this file to .env and fill in your keys.
# Do NOT put real keys in this template file — only in .env (which is gitignored).

# Groq — the LLM provider. Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Optional: override the default Groq model (must support tool calling)
GROQ_MODEL=llama-3.3-70b-versatile

# --- Phoenix CRM e-commerce products API ---
PHOENIX_API_BASE=https://staging-api.phoenixcrm.io/portal/api
PHOENIX_STORE_ID=185
# Bearer token for the Phoenix API. Keep this secret; rotate if leaked.
PHOENIX_API_TOKEN=eyJ...
